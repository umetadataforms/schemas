{
  "$id": "https://github.com/umetadataforms/schemas/raw/main/modular/tabular-data-metadata/v0.0.2.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tabular Data Metadata",
  "description": "Tabular dataset metadata.\n\nThis metadata schema provides a structured framework for defining and describing tabular data files. It enables clear, standardised documentation of file identity, integrity, and structure, as well as detailed characterisation of each field within the dataset. The schema captures essential information needed to interpret fields or variables, ensure their consistent definitions, assess data suitability,  and support harmonisation across datasets. This schema is intended to support reproducibility, interoperability, and transparent documentation, enabling downstream validation, dataset comparison, and integration into broader analytical workflows.\n\nReserved keywords: `unknown`, `not applicable`.\n\nComplete all applicable fields based on the available documentation and knowledge of the dataset.",
  "type": "object",
  "properties": {
    "schema": {
      "title": "Schema URI",
      "description": "Reference to the schema used.",
      "type": "string",
      "const": "https://github.com/umetadataforms/schemas/raw/main/modular/tabular-data-metadata/v0.0.2.json"
    },
    "files": {
      "title": "Files",
      "description": "Tabular data files with homogeneous structure and format.\n\n**Constraints**: *Maximum number* of files: 100,000.",
      "type": "array",
      "items": {
        "$ref": "https://github.com/umetadataforms/schemas/raw/main/modular/common/file/v0.0.1.json"
      },
      "uniqueItems": true,
      "maxItems": 100000
    },
    "fields": {
      "title": "Fields",
      "description": "List of fields or variables in the tabular data.\n\n**Constraints**: *Maximum number* of fields: 100,000.",
      "type": "array",
      "items": {
        "$ref": "https://github.com/umetadataforms/schemas/raw/main/modular/common/field/v0.0.2.json"
      },
      "uniqueItems": true,
      "maxItems": 100000
    }
  },
  "additionalProperties": false,
  "required": [
    "schema",
    "files",
    "fields"
  ],
  "examples": [
    {

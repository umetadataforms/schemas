{
  "$id": "https://github.com/umetadataforms/schemas/raw/main/modular/common/period/v0.0.2.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Period",
  "description": "A period with start and end dates.\n\n**Guidelines**: Make sure `startDate` ≤ `endDate`.",
  "type": "object",
  "properties": {
    "startDate": {
      "title": "Start Date",
      "anyOf": [
        {
          "$ref": "https://github.com/umetadataforms/schemas/raw/main/modular/common/date/v0.0.1.json"
        },
        {
          "$ref": "https://github.com/umetadataforms/schemas/raw/main/modular/common/unknown/v0.0.1.json"
        }
      ]
    },
    "endDate": {
      "title": "End Date",
      "anyOf": [
        {
          "$ref": "https://github.com/umetadataforms/schemas/raw/main/modular/common/date/v0.0.1.json"
        },
        {
          "$ref": "https://github.com/umetadataforms/schemas/raw/main/modular/common/unknown/v0.0.1.json"
        }
      ]
    }
  },
  "required": [
    "startDate",
    "endDate"
  ],
  "additionalProperties": false,
  "examples": [
    {
      "startDate": "2010-01-01",
      "endDate": "2020-12-31"
    },
    {
      "startDate": "unknown",
      "endDate": "2020-12-31"
    }
  ]
}
